@prefix ex: <http://example.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

# Example preload data — replace with your own domain knowledge.

ex:Robot1 a ex:Robot ;
    rdfs:label "Robot 1" .

ex:Robot2 a ex:Robot ;
    rdfs:label "Robot 2" .
